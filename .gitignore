# Sense Health — Root .gitignore
# Prevents node_modules, local keys, and system logs from being pushed to Git

# Dependencies
node_modules/
**/node_modules/

# Environment and Secrets (CRITICAL: prevents leaking your Gemini API Key)
.env
.env.local
.env.*.local
**/.env
**/.env.*

# Mobile/Expo Specific Files
mobile/.expo/
mobile/dist/
mobile/web-build/
mobile/ios/
mobile/android/
mobile/expo-env.d.ts
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro & Bundler cache
.metro-health-check*
**/.metro-health-check*

# Logs and Debugging
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS System Files
.DS_Store
.DS_Store?
**/_DS_Store
**/.DS_Store
Thumbs.db
ehthumbs.db

# IDE and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
